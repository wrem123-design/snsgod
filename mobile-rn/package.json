{
  "name": "snsgod-mobile-rn",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "check": "tsc --noEmit",
    "android:release": "set \"GRADLE_USER_HOME=%CD%\\.gradle-user-home\" && cd android && gradlew.bat :app:assembleRelease -x lint -x test",
    "android:install:release": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "android:crashlog": "adb logcat -d -b crash",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@types/jsrsasign": "^10.5.15",
    "expo": "^53.0.0",
    "expo-application": "^57.0.0",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "^18.1.11",
    "expo-image-picker": "~16.1.4",
    "expo-sharing": "~13.1.5",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "^2.2.3",
    "jsrsasign": "^11.1.3",
    "jszip": "^3.10.1",
    "react": "19.0.0",
    "react-native": "^0.79.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.8.3"
  }
}

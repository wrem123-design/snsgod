# Development only. Change to a long random value before deployment.
BOOTSTRAP_SECRET=change-this-before-deploying
PORT=8787
HOST=127.0.0.1
DATA_DIR=./data

# mock: local test replies only
# openai-compatible: Custom/Cerebras-compatible chat-completions endpoint
LLM_PROVIDER=mock
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# Long-outage recovery: health probe interval and maximum retry retention
API_HEALTH_CHECK_SECONDS=300
REPLY_JOB_RETENTION_HOURS=24
PROACTIVE_JOB_RETENTION_HOURS=6

# none: no push, clients still receive messages through sync
# fcm: Firebase HTTP v1 API using a service account file stored outside Git
PUSH_PROVIDER=none
FIREBASE_SERVICE_ACCOUNT_PATH=

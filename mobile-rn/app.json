{
  "expo": {
    "name": "SNSGod",
    "slug": "snsgod-mobile-rn",
    "version": "0.3.6",
    "orientation": "portrait",
    "scheme": "snsgod",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "android": {
      "package": "com.snsgod.rn",
      "permissions": []
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "snsgod_messages"
        }
      ],
      "expo-sharing",
      "expo-sqlite",
      "expo-status-bar"
    ]
  }
}
